# Minimal Mastodon config for local dev with OTEL tracing
LOCAL_DOMAIN=localhost:3000
LOCAL_HTTPS=false
ALTERNATE_DOMAINS=10.0.2.2:3000
SINGLE_USER_MODE=true

# Database (matches docker-compose service names)
DB_HOST=db
DB_USER=postgres
DB_NAME=postgres
DB_PASS=
DB_PORT=5432
REDIS_HOST=redis
REDIS_PORT=6379

# Disable Elasticsearch (not needed for this demo)
ES_ENABLED=false

# Secrets (generated for local dev only)
SECRET_KEY_BASE=f542eabd28d35580addcf1e720dcee4e48ba3b52cfa1f8faa415819883ab8ee5a87246f2990280a9a8423c4bcef3dd9fb85ee0754d6b46a75fd27622e1068b5c
OTP_SECRET=f704ee4ff0b6ae1e4be2badf952c9546679997f236f0f0913422ad802c473cf327b98214974063d8b2818c44047d6fd28f1c6f9cd0d3d1cf5db4f33b09fedc99

# Active Record encryption keys
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=n9ikRFboOYMwPLDUIFfWMP2cG2Yar8Km
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=Fukl4nvohmfgvaOb8w4lsBY9ACM3Ikcx
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=rHsNYATNbFFgJtcJUPzAtTRcAXPOpceW

# OTEL - export traces to TinyOlly's OTel Collector
